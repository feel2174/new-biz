WORDPRESS_URL="https://wordpress.com"
WORDPRESS_HOSTNAME="wordpress.com"

# If using the revalidate plugin
# You can generate by running `openssl rand -base64 32` in the terminal
WORDPRESS_WEBHOOK_SECRET="your-secret-key-here"

# Google AdSense
# 게시자 ID (ca-pub-XXXXXXXXXXXXXXXX). 기본값은 코드에 포함되어 있음.
NEXT_PUBLIC_ADSENSE_CLIENT="ca-pub-9196149361612087"
# AdSense 대시보드에서 발급한 광고 유닛 슬롯 ID (미설정 시 해당 위치 광고 미노출)
NEXT_PUBLIC_ADSENSE_SLOT_DISPLAY=""   # 홈 디스플레이 광고
NEXT_PUBLIC_ADSENSE_SLOT_LIST=""      # 목록(블로그) 광고
NEXT_PUBLIC_ADSENSE_SLOT_ARTICLE=""   # 글 본문(인아티클) 광고
